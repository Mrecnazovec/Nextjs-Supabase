generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum OrderStatus {
  pending
  confirmed
  processing
  delivered
}

enum GridEntityType {
  invoices
  orders
}

model Invoice {
  invoiceId      String        @id @map("invoice_id")
  customerName   String        @map("customer_name")
  customerEmail  String        @map("customer_email")
  invoiceDate    DateTime      @map("invoice_date")
  dueDate        DateTime      @map("due_date")
  amount         Decimal       @db.Decimal(12, 2)
  tax            Decimal       @db.Decimal(5, 2)
  total          Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus
  paymentMethod  String?       @map("payment_method")
  notes          String?

  @@map("invoices")
}

model Order {
  orderId            String      @id @map("order_id")
  customerName       String      @map("customer_name")
  customerPhone      String      @map("customer_phone")
  orderDate          DateTime    @map("order_date")
  shippingAddress    String      @map("shipping_address")
  itemsCount         Int         @map("items_count")
  subtotal           Decimal     @db.Decimal(12, 2)
  shippingCost       Decimal     @db.Decimal(12, 2) @map("shipping_cost")
  discount           Decimal     @db.Decimal(5, 2)
  total              Decimal     @db.Decimal(12, 2)
  status             OrderStatus
  trackingNumber     String?     @map("tracking_number")
  estimatedDelivery  DateTime?   @map("estimated_delivery")

  @@map("orders")
}

model View {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  name         String
  entityType   GridEntityType @map("entity_type")
  columnState  Json           @map("column_state")
  sortModel    Json           @map("sort_model")
  filterModel  Json           @map("filter_model")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([userId, entityType])
  @@map("views")
}
